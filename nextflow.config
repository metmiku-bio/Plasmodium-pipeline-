// Nextflow configuration file

profiles {
    standard {
        process {
            cpus = 8
            memory = '60 GB'
            time = '24 h'
            beforeScript = 'eval "$(conda shell.bash hook)" && conda activate nf-core'
        }
    }

    test {
        process {
            cpus = 2
            memory = '8 GB'
            time = '1 h'
            beforeScript = 'eval "$(conda shell.bash hook)" && conda activate nf-core'
        }
    }

    conda {
        conda {
            enabled = true
        }
    }

    docker {
        docker {
            enabled = true
        }
        process.container = 'broadinstitute/gatk:4.2.2.0'
    }
    
    singularity {
        singularity {
            enabled = true
            autoMounts = true
        }
        process.container = 'broadinstitute/gatk:4.2.2.0'
    }
}

process {
    withName: BAM_PREP {
        cpus = 8
        memory = '4 GB'
        time = '24 h'
    }

    withName: BAM_STATS {
        cpus = 4
        memory = '60 GB'
        time = '12 h'
    }

    withName: HAPLOTYPE_CALLER {
        cpus = 16
        memory = '4 GB'
        time = '72 h'
    }

    withName: GENOMICSDB_IMPORT {
        cpus = 24
        memory = '40 GB'
        time = '24 h'
    }

    withName: GENOTYPE_GVCF {
        cpus = 8
        memory = '4 GB'
        time = '72 h'
    }

    withName: GATHER_VCFS {
        cpus = 4
        memory = '4 GB'
        time = '12 h'
    }

    withName: VARIANT_RECALIBRATOR {
        cpus = 4
        memory = '4 GB'
        time = '24 h'
    }

    withName: APPLY_VQSR {
        cpus = 4
        memory = '4 GB'
        time = '12 h'
    }
}
