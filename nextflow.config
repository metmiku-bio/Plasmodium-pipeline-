// Nextflow configuration file

profiles {
    standard {
        process {
            cpus = 16
            memory = '32 GB'
            time = '72 h'
            beforeScript = 'eval "$(conda shell.bash hook)" && conda activate nf-core'
        }
    }

    test {
        process {
            cpus = 2
            memory = '8 GB'
            time = '1 h'
            beforeScript = 'eval "$(conda shell.bash hook)" && conda activate nf-core'
        }
    }

    hpc {
        executor = 'slurm'
        process {
            cpus = 32
            memory = '64 GB'
            time = '72 h'
            queue = 'normal'
            beforeScript = 'eval "$(conda shell.bash hook)" && conda activate nf-core'
        }
    }

    conda {
        conda.enabled = true
    }

    docker {
        docker.enabled = true
        process.container = 'broadinstitute/gatk:4.2.2.0'
    }

    singularity {
        singularity {
            enabled = true
            autoMounts = true
        }
        process.container = 'broadinstitute/gatk:4.2.2.0'
    }
}

// ======================== Process-specific resources ========================
process {
    withName: HAPLOTYPE_CALLER {
        cpus = 32
        memory = '64 GB'
        time = '72 h'
    }

    withName: GENOTYPE_GVCFS {
        cpus = 8
        memory = '16 GB'
        time = '24 h'
    }

    withName: VARIANT_RECALIBRATOR {
        cpus = 8
        memory = '32 GB'
        time = '12 h'
    }

    withName: VARIANT_RECALIBRATOR_SNP {
        cpus = 8
        memory = '32 GB'
        time = '12 h'
    }

    withName: APPLY_VQSR {
        cpus = 4
        memory = '16 GB'
        time = '6 h'
    }

    withName: APPLY_VQSR_SNP {
        cpus = 4
        memory = '16 GB'
        time = '6 h'
    }
}

// ======================== Performance tuning ========================
executor {
    name = 'local'
    queueSize = 100
    pollInterval = '5 sec'
    exitRead = '10 KB'
    maxRetries = 2
    cacheable = true
}

// Enable parallel execution (run independent tasks simultaneously)
process {
    maxForks = 8
    errorStrategy = 'retry'
    maxRetries = 2
    cache = 'lenient'
}
